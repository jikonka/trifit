# TriFit Weather Proxy - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git!

OWM_API_KEY=
PORT=3001

# Optional: additional allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000

# --- Supabase (for reference only — used in frontend auth.js, not in backend) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# Note: The frontend connects to Supabase directly via the anon key.
# The backend server does NOT need these values — they are listed here
# as a reference for the project's environment variable inventory.
